# Server host/port
HOST=127.0.0.1
PORT=5000

# Choose one or set multiple. Generic chat routes prefer OpenAI unless a Claude key is sent from UI.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional model overrides
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_VISION_MODEL=gpt-5.4
GEMINI_VISION_MODEL=gemini-2.5-pro
